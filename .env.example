# メール送信設定（GitHub Secrets に登録する値のテンプレート）
EMAIL_FROM=your-address@gmail.com
EMAIL_TO=recipient@example.com
EMAIL_PASS=your-app-password          # Gmailはアプリパスワードを使用
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# スクリーニング条件（省略時はデフォルト値が使われます）
MIN_YIELD=2.5        # 配当利回り下限 (%)
MAX_YIELD=10.0       # 配当利回り上限 (%) ― 高すぎる銘柄を除外
MIN_STREAK=5         # 連続配当年数の最低値
MAX_PAYOUT=75.0      # 配当性向上限 (%)
MAX_DEBT_EQUITY=2.0  # 負債資本比率 (D/E) 上限
MIN_CURRENT=1.0      # 流動比率 下限
